MQTT_HOST=localhost
MQTT_PORT=1883
MQTT_USERNAME=doorbell
MQTT_PASSWORD=changeme
MQTT_CLIENT_ID=
MQTT_TLS_ENABLED=false
MQTT_TLS_CA_CERT=

INTENT_ENGINE_IMAGE=doorbell-intent-engine:latest
WEB_UI_IMAGE=doorbell-web-ui:latest
WEB_UI_PORT=8080


MQTT_TOPIC_FRIGATE=frigate/events
MQTT_TOPIC_DOORBELL_PRESS=doorbell/doorbell_press
MQTT_TOPIC_HUMAN_ACTIVE=doorbell/human_active
MQTT_TOPIC_DIALOGUE_ANSWER=doorbell/dialogue/answer
MQTT_TOPIC_SESSION_STATE=doorbell/session/state
MQTT_TOPIC_INTENT=doorbell/intent
MQTT_TOPIC_TTS_REQUEST=doorbell/tts/request
MQTT_TOPIC_TTS_STATUS=doorbell/tts/status
MQTT_TOPIC_ESCALATE=doorbell/escalate

LLM_ENABLED=true
LLM_MODEL=llama3.2:3b
OLLAMA_HOST=http://localhost:11434
LLM_TIMEOUT_S=8

CONFIDENCE_AUTO_HANDLE=0.75
CONFIDENCE_CLARIFY=0.5
CLARIFICATION_MAX=2
SAFETY_KEYWORDS=police,emergency,fire,gas,leak,injury,weapon,warrant,lawsuit,sign,contract

